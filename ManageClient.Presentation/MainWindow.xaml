<Window x:Class="ManageClient.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Manage Clients" Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2D6CDF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A56C4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1445A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E03E3E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B2B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8A4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Client Management"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2D6CDF"
                   Margin="0,0,0,16"/>

        <!-- Form -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.08" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Full Name -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Full Name" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtFullName" Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <!-- Phone -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Phone Number" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtPhone" Style="{StaticResource InputStyle}"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtEmail" Style="{StaticResource InputStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons + DataGrid -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">
                <Button x:Name="BtnSave"
                        Content="💾 Save"
                        Style="{StaticResource SuccessBtn}"
                        Width="100"
                        Margin="0,0,8,0"
                        Click="BtnSave_Click"/>
                <Button x:Name="BtnDelete"
                        Content="🗑 Delete"
                        Style="{StaticResource DangerBtn}"
                        Width="100"
                        Margin="0,0,8,0"
                        Click="BtnDelete_Click"/>
                <Button x:Name="BtnClear"
                        Content="✖ Clear"
                        Style="{StaticResource PrimaryBtn}"
                        Width="100"
                        Click="BtnClear_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      x:Name="DgClients"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="White"
                      BorderBrush="#DDD"
                      BorderThickness="1"
                      RowBackground="White"
                      AlternatingRowBackground="#F9F9F9"
                      SelectionChanged="DgClients_SelectionChanged">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2D6CDF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontSize" Value="13"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="60"/>
                    <DataGridTextColumn Header="Full Name"   Binding="{Binding FullName}"    Width="*"/>
                    <DataGridTextColumn Header="Phone"       Binding="{Binding PhoneNumber}" Width="150"/>
                    <DataGridTextColumn Header="Email"       Binding="{Binding Email}"       Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>